{
  "mcpServers": {
    "github": {
      "command": "op",
      "args": [
        "run",
        "--env-file=/Users/YOUR_USERNAME/.config/op/mcp.env",
        "--no-masking",
        "--",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github",
        "--toolsets",
        "repos,issues"
      ],
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  }
}
